# Copy to terraform.tfvars (gitignored) and set values.
# Or: export TF_VAR_anthropic_api_key="..."

aws_region          = "eu-west-2"
project_name        = "carbon-agent"
ecr_repository_name = "carbon-agent-api"

# Required: Anthropic API key for the running task (stored in Secrets Manager).
anthropic_api_key = ""

# Optional: pin image after first ECR push if you need to avoid :latest during bootstrap.
# api_image = "123456789012.dkr.ecr.eu-west-2.amazonaws.com/carbon-agent-api:latest"
